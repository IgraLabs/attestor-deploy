# Igra Attestor - Mainnet Configuration
#
# Prerequisites:
#   - igra-orchestra must be running with the backend and frontend-w1 profiles
#   - The attestor connects to rpc-provider via the shared Docker network
#
# Setup:
#   1. Run: ./setup.sh mainnet
#   2. Follow the prompts to enter your private key

# --- Network ---
# Must match the NETWORK value in your igra-orchestra .env
NETWORK=mainnet

# --- Attestor ---
ATTESTOR_VERSION=2.3.0
CONTRACT_ADDRESS=0xc24Df70E408739aeF6bF594fd41db4632dF49188
CHAIN_ID=38833

# --- Logging ---
RUST_LOG=igra_attestation=info

# --- Optional ---
# RPC_URL=http://rpc-provider-0:8535
# HEALTH_PORT=8180
# METRICS_PORT=9190
# REORG_SAFETY_BLOCKS=30
